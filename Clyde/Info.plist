<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>Clyde</string>
    <key>CFBundleIdentifier</key>
    <string>io.github.kl0sin.clyde</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Clyde</string>
    <key>CFBundleDisplayName</key>
    <string>Clyde</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>NSAppleEventsUsageDescription</key>
    <string>Clyde uses AppleScript to focus terminal windows containing Claude Code sessions.</string>

    <!-- Sparkle auto-update configuration. -->
    <!-- Replace kl0sin with the actual GitHub user/org once the
         repo is live. The feed XML is hosted alongside the landing page
         on GitHub Pages so it's served from the same origin as the site. -->
    <key>SUFeedURL</key>
    <string>https://kl0sin.github.io/clyde/appcast.xml</string>
    <!-- EdDSA public key — generated by Sparkle's `generate_keys` tool.
         Matching private key stays on the release machine / GitHub Secret
         and is used to sign DMG payloads. Without a valid signature
         Sparkle refuses to install. -->
    <key>SUPublicEDKey</key>
    <string>d90ecLzhadif16wQ17K4m1Kf+tDfH0BIJgwcB1SkK+k=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <!-- Daily automatic check (in seconds). -->
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
